# .env.example
# Copy this file to .env and configure the variables for your environment.

# ── DATABASE CONFIGURATION ───────────────────────────────────────────────────
# Connection string for production PostgreSQL (e.g. Supabase).
# Example: postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://username:password@hostname:port/dbname

# ── APPLICATION ENVIRONMENT ──────────────────────────────────────────────────
# Set to 'production' to enable secure cross-site cookies (https).
# Set to 'development' for local localhost tests.
ENV=development
SECURE_COOKIES=false

# ── SECURITY CONFIGURATION ───────────────────────────────────────────────────
# Random long secret key used to sign JWT session cookies.
# Generate one using: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=super_secret_session_key_1234567890!

# CORS configuration: the URL where your Next.js frontend is running.
FRONTEND_URL=http://localhost:3000

# ── GOOGLE GEMINI LLM CONFIGURATION ──────────────────────────────────────────
# Get your API key from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── NEWS FEED CONFIGURATION ──────────────────────────────────────────────────
# Get your API key from Currents News API (https://currentsapi.services/)
CURRENTS_API_KEY=your_currents_api_key_here

# ── CLOUD STORAGE CONFIGURATION (S3) ────────────────────────────────────────
# Configure these to save files permanently in AWS S3 or Supabase Storage bucket.
# Set USE_S3 to 'true' to enable. Leave as 'false' to save files locally on disk.
USE_S3=false
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_STORAGE_BUCKET_NAME=your_s3_bucket_name_here
AWS_S3_REGION_NAME=us-east-1
